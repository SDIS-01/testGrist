<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Formulaire Grist</title>
<script src="https://docs.getgrist.com/grist-plugin-api.js"></script>
<style>
  :root {
    --accent: #16a34a;
    --accent-dark: #15803d;
    --bg: #f8fafc;
    --border: #e2e8f0;
    --text: #1e293b;
    --muted: #64748b;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 24px;
  }
  .wrap { max-width: 520px; margin: 0 auto; }
  h1 { font-size: 18px; margin: 0 0 4px; }
  .subtitle { color: var(--muted); font-size: 13px; margin-bottom: 20px; }
  .table-select {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 14px;
    background: white;
  }
  form { display: flex; flex-direction: column; gap: 14px; }
  label { font-size: 13px; font-weight: 600; margin-bottom: 4px; display: block; }
  input, select, textarea {
    width: 100%;
    padding: 9px 10px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    background: white;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(22,163,74,0.15);
  }
  .checkbox-row { display: flex; align-items: center; gap: 8px; }
  .checkbox-row input { width: auto; }
  button {
    margin-top: 8px;
    padding: 11px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }
  button:hover { background: var(--accent-dark); }
  button:disabled { background: #94a3b8; cursor: not-allowed; }
  .msg {
    margin-top: 14px;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 13px;
    display: none;
  }
  .msg.success { display: block; background: #dcfce7; color: #166534; }
  .msg.error { display: block; background: #fee2e2; color: #991b1b; }
  .note { font-size: 12px; color: var(--muted); margin-top: 16px; line-height: 1.5; }
  .empty-state { color: var(--muted); font-size: 14px; padding: 20px 0; text-align: center; }
</style>
</head>
<body>
<div class="wrap">
  <h1>📋 Formulaire Grist</h1>
  <div class="subtitle">Les champs sont générés automatiquement depuis les colonnes de la table.</div>

  <select id="tableSelect" class="table-select"></select>

  <form id="form"></form>
  <div id="msg" class="msg"></div>
  <div id="excludedNote" class="note"></div>
</div>

<script>
  let currentTableId = null;
  let currentColumns = [];

  grist.ready({
    requiredAccess: 'full',
  });

  async function init() {
    const tableIds = await grist.docApi.listTables();
    const select = document.getElementById('tableSelect');
    select.innerHTML = tableIds.map(t => `<option value="${t}">${t}</option>`).join('');

    const saved = await grist.getOption('tableId');
    if (saved && tableIds.includes(saved)) {
      select.value = saved;
    }

    select.addEventListener('change', async () => {
      await grist.setOption('tableId', select.value);
      await loadForm(select.value);
    });

    if (select.value) {
      await loadForm(select.value);
    }
  }

  async function loadForm(tableId) {
    currentTableId = tableId;
    const formEl = document.getElementById('form');
    formEl.innerHTML = '<div class="empty-state">Chargement des colonnes…</div>';
    document.getElementById('excludedNote').textContent = '';
    hideMsg();

    try {
      const tables = await grist.docApi.fetchTable('_grist_Tables');
      const tableIdx = tables.tableId.indexOf(tableId);
      if (tableIdx === -1) throw new Error('Table introuvable');
      const tableRef = tables.id[tableIdx];

      const cols = await grist.docApi.fetchTable('_grist_Tables_column');
      const rows = [];
      for (let i = 0; i < cols.id.length; i++) {
        if (cols.parentId[i] !== tableRef) continue;
        if (cols.isFormula[i]) continue;
        const colId = cols.colId[i];
        if (colId === 'manualSort' || colId.startsWith('gristHelper_')) continue;
        rows.push({
          colId,
          label: cols.label[i] || colId,
          type: cols.type[i] || 'Text',
          widgetOptions: cols.widgetOptions[i] || '',
        });
      }

      currentColumns = rows.filter(c => !/^(Ref|RefList|Attachments)/.test(c.type));
      const excluded = rows.filter(c => /^(Ref|RefList|Attachments)/.test(c.type));

      if (excluded.length) {
        document.getElementById('excludedNote').textContent =
          'Colonnes non incluses (références ou pièces jointes, non gérées par ce formulaire) : ' +
          excluded.map(c => c.label).join(', ');
      }

      renderForm(currentColumns);
    } catch (err) {
      formEl.innerHTML = '<div class="empty-state">Erreur de chargement des colonnes.</div>';
      console.error(err);
    }
  }

  function renderForm(columns) {
    const formEl = document.getElementById('form');
    if (!columns.length) {
      formEl.innerHTML = '<div class="empty-state">Aucune colonne modifiable trouvée dans cette table.</div>';
      return;
    }

    formEl.innerHTML = columns.map(col => renderField(col)).join('') +
      '<button type="submit">Envoyer</button>';

    formEl.onsubmit = handleSubmit;
  }

  function renderField(col) {
    const id = 'f_' + col.colId;
    const type = col.type;

    if (type === 'Bool') {
      return `
        <div class="checkbox-row">
          <input type="checkbox" id="${id}" data-col="${col.colId}" data-type="${type}" />
          <label for="${id}" style="margin:0;">${col.label}</label>
        </div>`;
    }

    if (type === 'Choice') {
      let choices = [];
      try {
        const opts = JSON.parse(col.widgetOptions || '{}');
        choices = opts.choices || [];
      } catch (e) {}
      const options = ['<option value="">— choisir —</option>']
        .concat(choices.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`));
      return `
        <div>
          <label for="${id}">${col.label}</label>
          <select id="${id}" data-col="${col.colId}" data-type="${type}">${options.join('')}</select>
        </div>`;
    }

    let inputType = 'text';
    if (type === 'Numeric') inputType = 'number';
    else if (type === 'Int') inputType = 'number';
    else if (type === 'Date') inputType = 'date';
    else if (type.startsWith('DateTime')) inputType = 'datetime-local';

    const step = type === 'Numeric' ? 'any' : (type === 'Int' ? '1' : null);

    return `
      <div>
        <label for="${id}">${col.label}</label>
        <input type="${inputType}" id="${id}" data-col="${col.colId}" data-type="${type}"
          ${step ? `step="${step}"` : ''} />
      </div>`;
  }

  function escapeHtml(str) {
    return String(str).replace(/[&<>"']/g, c => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));
  }

  async function handleSubmit(e) {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.disabled = true;
    hideMsg();

    try {
      const fields = {};
      currentColumns.forEach(col => {
        const el = document.getElementById('f_' + col.colId);
        const type = col.type;
        let value = null;

        if (type === 'Bool') {
          value = el.checked;
        } else if (type === 'Numeric') {
          value = el.value === '' ? null : parseFloat(el.value);
        } else if (type === 'Int') {
          value = el.value === '' ? null : parseInt(el.value, 10);
        } else if (type === 'Date') {
          value = el.value ? Math.floor(new Date(el.value + 'T00:00:00Z').getTime() / 1000) : null;
        } else if (type.startsWith('DateTime')) {
          value = el.value ? Math.floor(new Date(el.value).getTime() / 1000) : null;
        } else {
          value = el.value === '' ? null : el.value;
        }

        fields[col.colId] = value;
      });

      const table = grist.getTable(currentTableId);
      await table.create({ fields });

      showMsg('success', '✓ Enregistrement ajouté avec succès.');
      e.target.reset();
    } catch (err) {
      console.error(err);
      showMsg('error', 'Erreur lors de l’envoi : ' + (err.message || err));
    } finally {
      btn.disabled = false;
    }
  }

  function showMsg(type, text) {
    const msg = document.getElementById('msg');
    msg.className = 'msg ' + type;
    msg.textContent = text;
  }

  function hideMsg() {
    const msg = document.getElementById('msg');
    msg.className = 'msg';
    msg.textContent = '';
  }

  init();
</script>
</body>
</html>
